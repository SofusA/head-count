{
  "name": "count",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:status": "esbuild src/client/status.ts --bundle --outfile=build/static/status.js --platform=browser --minify",
    "build:dashboard": "esbuild src/client/dashboard.ts --bundle --outfile=build/static/dashboard.js --platform=browser --minify",
    "build:monitor": "esbuild src/client/monitor.ts --bundle --outfile=build/static/monitor.js --platform=browser --minify",
    "build:export": "esbuild src/client/export.ts --bundle --outfile=build/static/export.js --platform=browser --minify",
    "init-build": "rm -rf build && mkdir -p build/skylab",
    "copy": "cp -r src/views/* build/skylab && cp -r src/static build",
    "rename-dashboard": "mv build/skylab/dashboard.html build/skylab/index.html",
    "build": "npm run init-build && npm run build:status && npm run build:dashboard && npm run build:monitor && npm run build:export && npm run copy && npm run rename-dashboard",
    "serve": "serve build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^1.24.0",
    "apexcharts": "^3.29.0",
    "esbuild": "^0.20.0",
    "luxon": "^2.0.2",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "serve": "^14.2.6"
  }
}
